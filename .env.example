# Copy to `.env.local` for local dev (never commit real secrets).

# --- Supabase (dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public origin of this app — no trailing slash (OAuth redirects, unsubscribe links).
# Local: http://localhost:3000 — Production: https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (Cloud Console → APIs & Credentials) for “Connect Gmail”
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# --- Server secrets (generate: openssl rand -hex 32)
#
# CRON_SECRET — If set, POST /api/campaign/dispatch requires:
#   Authorization: Bearer <CRON_SECRET>
# If unset, the dispatch route is open (only use behind a private network / lock down later).
#
# UNSUBSCRIBE_SECRET — Signs one-click unsubscribe links (`/api/unsubscribe`).
# If unset, CRON_SECRET is used for signing instead (one secret for both).
CRON_SECRET=d2c536c6c25cacf905f1014327a2971e2998cf581f395b0c657db3279f226ce6
UNSUBSCRIBE_SECRET=09cae602c5b4132e79134b71d98164273c3d02c6084ae125c066be5f12024e80
