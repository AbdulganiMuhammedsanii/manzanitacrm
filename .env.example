# Copy to `.env.local` for local dev (never commit real secrets).

# --- Supabase (dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public origin of this app — no trailing slash (OAuth redirects, unsubscribe links).
# Local: http://localhost:3000 — Production: https://your-app.up.railway.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google OAuth (Cloud Console → APIs & Credentials) for “Connect Gmail”
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Server secrets (generate: openssl rand -hex 32)
#
# CRON_SECRET — If set, POST /api/campaign/dispatch requires:
#   Authorization: Bearer <CRON_SECRET>
#
# UNSUBSCRIBE_SECRET — Signs one-click unsubscribe URLs. If unset, CRON_SECRET is used.
CRON_SECRET=
UNSUBSCRIBE_SECRET=

# --- Tracked PDF / file links (optional)
# Signed links: GET /v/<token> → log open in asset_open_events → redirect to S3 presigned GET.
# ASSET_TRACK_SECRET — If unset, UNSUBSCRIBE_SECRET or CRON_SECRET is used (same HMAC pattern as unsubscribe).
# TRACKED_ASSET_ID — UUID of a row in tracked_assets; when set, {{pdf_link}} / {{tracked_pdf_url}} / {{asset_link}} resolve in campaign emails.
# AWS + bucket: IAM user or instance role; bucket can be defaulted via env if tracked_assets.s3_bucket is null.
ASSET_TRACK_SECRET=
TRACKED_ASSET_ID=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Default S3 bucket when tracked_assets.s3_bucket is null
AWS_S3_BUCKET=
# Alias for AWS_S3_BUCKET (either works)
PDF_ASSETS_BUCKET=
